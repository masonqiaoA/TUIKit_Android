<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@drawable/bg_smart_cellular_dialog"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/smart_cellular_title"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_wifi_icon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:contentDescription="WiFi Poor Signal" />

            <TextView
                android:id="@+id/tv_wifi_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/smart_cellular_wifi_poor"
                android:textColor="#333333"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/iv_arrow"
            android:layout_width="35dp"
            android:layout_height="25dp"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="Arrow" />

        <LinearLayout
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_cellular_icon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:contentDescription="Cellular Good Signal" />

            <TextView
                android:id="@+id/tv_cellular_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/smart_cellular_cellular_good"
                android:textColor="#333333"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="@string/smart_cellular_description"
        android:textColor="#666666"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btn_improve"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_smart_cellular_improve_button"
        android:text="@string/smart_cellular_improve"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_keep_wifi"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_smart_cellular_keep_wifi_button"
        android:text="@string/smart_cellular_keep_wifi"
        android:textColor="#333333"
        android:textSize="16sp" />

</LinearLayout>