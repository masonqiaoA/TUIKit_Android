<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="RoomKitBottomDialog" parent="Theme.Design.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
        <item name="android:windowAnimationStyle">@style/RoomKitBottomDialogAnimation</item>
    </style>

    <style name="RoomKitCenterDialog" parent="@android:style/Theme.Holo.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
        <item name="android:windowAnimationStyle">@style/RoomKitCenterDialogAnimation</item>
    </style>

    <style name="RoomKitCenterDialogAnimation" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/roomkit_fade_in</item>
        <item name="android:windowExitAnimation">@anim/roomkit_fade_out</item>
    </style>

    <style name="RoomKitBottomDialogAnimation" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/roomkit_slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/roomkit_slide_out_bottom</item>
    </style>

    <style name="RoomKitTabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
</resources>
