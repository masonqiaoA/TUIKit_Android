<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/roomkit_color_room_background">

    <com.trtc.uikit.roomkit.view.main.RoomTopBarView
        android:id="@+id/room_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.trtc.uikit.roomkit.view.main.RoomView
        android:id="@+id/room_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/room_bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/room_top_bar"
        app:layout_constraintVertical_weight="1" />

    <com.trtc.uikit.roomkit.aitranscription.subtitleview.AISubtitleView
        android:id="@+id/ai_subtitle_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/room_bottom_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.trtc.uikit.roomkit.view.main.RoomAIRecordFloatingView
        android:id="@+id/ai_record_floating_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="10dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/room_top_bar" />

    <com.trtc.uikit.roomkit.view.main.RoomBottomBarView
        android:id="@+id/room_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.trtc.uikit.roomkit.barrage.BarrageInputView
        android:id="@+id/barrage_input_view"
        android:layout_width="130dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="10dp"
        android:alpha="0.5"
        android:background="@drawable/roomkit_barrage_button_bg"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/room_bottom_bar"
        app:layout_constraintStart_toStartOf="parent" />

    <com.trtc.uikit.roomkit.barrage.BarrageStreamView
        android:id="@+id/barrage_stream_view"
        android:layout_width="match_parent"
        android:layout_height="206dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="45dp"
        android:layout_marginBottom="15dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/barrage_input_view" />

    <com.trtc.uikit.roomkit.view.main.screenshare.ScreenShareOverlayView
        android:id="@+id/screen_share_overlay_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/room_view"
        app:layout_constraintEnd_toEndOf="@+id/room_view"
        app:layout_constraintStart_toStartOf="@+id/room_view"
        app:layout_constraintTop_toTopOf="@+id/room_view" />
</androidx.constraintlayout.widget.ConstraintLayout>
