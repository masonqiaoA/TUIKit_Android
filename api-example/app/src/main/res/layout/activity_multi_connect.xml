<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Video rendering area (placeholder for LiveCoreView, dynamically added in code) -->
    <FrameLayout
        android:id="@+id/videoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <TextView
            android:id="@+id/tvLiveID"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:maxLines="2"
            android:breakStrategy="simple" />

    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Online audience count label (below toolbar, right side) -->
    <TextView
        android:id="@+id/audienceCountLabel"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_gravity="end"
        android:layout_marginTop="?attr/actionBarSize"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_audience_count"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Bottom co-hosting button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCoGuest"
        style="@style/Widget.App.Button.Circle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#CC4CAF50"
        android:visibility="gone"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:icon="@drawable/ic_person"
        app:iconSize="20dp"
        app:iconTint="@android:color/white" />

    <!-- Start live button (anchor only, center-bottom) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartLive"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="100dp"
        android:text="@string/basicStreaming_startLive"
        android:textSize="18sp"
        android:visibility="gone" />

</FrameLayout>
