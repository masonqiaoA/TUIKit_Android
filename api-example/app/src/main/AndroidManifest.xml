<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Camera permission -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Microphone permission -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Bluetooth permission (audio devices) -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Foreground service (keep live session alive) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.AtomicXCoreExample"
        tools:targetApi="35"
        tools:replace="android:allowBackup">

        <!-- Splash page -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AtomicXCoreExample.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login page -->
        <activity
            android:name=".scenes.login.LoginActivity"
            android:exported="false" />

        <!-- Profile setup page -->
        <activity
            android:name=".scenes.login.ProfileSetupActivity"
            android:exported="false" />

        <!-- Feature list page -->
        <activity
            android:name=".scenes.featurelist.FeatureListActivity"
            android:exported="false" />

        <!-- Basic streaming page -->
        <activity
            android:name=".scenes.basicstreaming.BasicStreamingActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.AtomicXCoreExample.Transparent" />

        <!-- Real-time interaction page -->
        <activity
            android:name=".scenes.interactive.InteractiveActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.AtomicXCoreExample.Transparent" />

        <!-- Audience co-hosting page -->
        <activity
            android:name=".scenes.multiconnect.MultiConnectActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.AtomicXCoreExample.Transparent" />

        <!-- Live PK page -->
        <activity
            android:name=".scenes.livepk.LivePKActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.AtomicXCoreExample.Transparent" />
    </application>
</manifest>
